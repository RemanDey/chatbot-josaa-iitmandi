# Gemini LLM settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_SECOND_API_KEY=your_gemini_second_api_key_here
GEMINI_THIRD_API_KEY=your_gemini_third_api_key_here

# Groq LLM settings (Primary)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter LLM settings (Fallback 1)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# DeepSeek LLM settings (Fallback 2)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Nvidia LLM settings (Fallback 3)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3-70b-instruct

# Hugging Face Inference settings (Fallback 4)
# HF_API_KEY (HF_TOKEN is also supported)
HF_API_KEY=your_hf_api_key_here
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct



# Runtime / deployment
APP_ENV=development
EAGER_LOAD_MODELS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,https://chatbot-josaa-iitmandi.onrender.com
WARMUP_TOKEN=
API_KEY=
# Embedding model (downloaded automatically from HuggingFace, no key needed)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ChromaDB persistent storage path
CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION_NAME=iitmandi
BM25_PICKLE_FILE=data/bm25_corpus.pkl

# Number of chunks to retrieve per query
TOP_K=20